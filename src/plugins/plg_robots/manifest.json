{
  "schema_version": "1.0",
  "name": "plg_robots",
  "type": "plugin",
  "vendor": "klucon",
  "extension_id": "klucon/plg_robots",
  "version": "0.1.1",
  "display_name": "Robots.txt",
  "display_name_key": "extensions.name.plg_robots",
  "description": "Spravuje /robots.txt. Obsah je editovatelný v administraci.",
  "license": "MIT",
  "author": {
    "name": "KLUCON",
    "url": "https://klucon.cz"
  },
  "links": {
    "homepage": "https://marketplace.klucon.cz",
    "repository": "https://github.com/klucon/plg_robots"
  },
  "compatibility": {
    "core_min": "0.2.0",
    "core_max": null,
    "python": ">=3.12",
    "database": [
      "mysql",
      "postgresql"
    ]
  },
  "package": {
    "entrypoint": "src.plugins.plg_robots",
    "setup_function": "setup",
    "admin_router": "admin.router"
  },
  "permissions": [
    {
      "key": "robots.manage",
      "label": "permissions.robots.manage"
    }
  ],
  "i18n": {
    "domain": "plg_robots",
    "locales_path": "i18n",
    "required_locales": [
      "cs_CZ",
      "en_GB"
    ]
  },
  "migrations": {
    "enabled": false,
    "path": "migrations"
  },
  "security": {
    "requires_signature": true,
    "capabilities": [
      "admin.routes",
      "web.routes",
      "database.read",
      "database.write"
    ]
  },
  "marketplace": {
    "category": "seo",
    "tags": [
      "robots",
      "seo",
      "crawl"
    ],
    "featured": false
  },
  "changelog": "První vydání: správa robots.txt přes administraci."
}
